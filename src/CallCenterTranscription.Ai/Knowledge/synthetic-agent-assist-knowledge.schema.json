{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contoso.example/schemas/synthetic-agent-assist-knowledge.v1.schema.json",
  "title": "SyntheticAgentAssistKnowledgeItem",
  "description": "Flat JSONL knowledge-item schema for propane call-center agent assist ingestion.",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "id",
    "document_id",
    "chunk_index",
    "chunk_count",
    "title",
    "category",
    "subcategory",
    "tags",
    "customer_intents",
    "trigger_phrases",
    "keywords",
    "customer_profile_signals",
    "answer",
    "retrieval_text",
    "rep_guidance",
    "next_best_action",
    "do_not_say",
    "escalation_required",
    "escalation_target",
    "escalation_reason",
    "priority",
    "authorization_notes",
    "trigger_locales",
    "source_type",
    "source_title",
    "source_section",
    "source_uri",
    "citation_label",
    "business_line",
    "channel",
    "locale",
    "last_reviewed"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "record_type": {
      "type": "string",
      "const": "knowledge_item"
    },
    "id": {
      "type": "string",
      "pattern": "^kb-[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "category": {
      "type": "string"
    },
    "subcategory": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "customer_intents": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "trigger_phrases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "customer_profile_signals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "answer": {
      "type": "string",
      "minLength": 30
    },
    "rep_guidance": {
      "type": "string",
      "minLength": 30
    },
    "next_best_action": {
      "type": "string",
      "minLength": 10
    },
    "do_not_say": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "escalation_required": {
      "type": "boolean"
    },
    "escalation_target": {
      "type": [
        "string",
        "null"
      ]
    },
    "escalation_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "normal",
        "medium",
        "high",
        "critical"
      ]
    },
    "source_type": {
      "type": "string"
    },
    "business_line": {
      "type": "string",
      "const": "propane-retail"
    },
    "channel": {
      "type": "string",
      "const": "voice"
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}-[A-Z]{2}$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date-time"
    },
    "authorization_notes": {
      "type": "string",
      "minLength": 15
    },
    "trigger_locales": {
      "type": "array",
      "description": "Locales represented in retrieval phrases or keywords for this record; does not imply translated answer text.",
      "items": {
        "type": "string",
        "pattern": "^[a-z]{2}-[A-Z]{2}$",
        "minLength": 5
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "document_id": {
      "type": "string",
      "pattern": "^doc-[a-z0-9-]+$",
      "description": "Stable parent document identifier shared by all chunks from the same article or playbook section."
    },
    "chunk_index": {
      "type": "integer",
      "minimum": 0,
      "description": "Zero-based position of this chunk within the source document."
    },
    "chunk_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Total number of chunks emitted for the parent document."
    },
    "retrieval_text": {
      "type": "string",
      "minLength": 80,
      "description": "Single concatenated text field for vectorization or lexical indexing when the target search service expects one primary retrievable body."
    },
    "source_title": {
      "type": "string",
      "minLength": 5,
      "description": "Human-readable source title to show in citations and knowledge-card provenance."
    },
    "source_section": {
      "type": "string",
      "minLength": 3,
      "description": "Source section or subsection label used to pinpoint where the answer came from within the source."
    },
    "source_uri": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9+.-]*://.+$",
      "description": "Canonical source URI for citations. May be synthetic:// for mocked corpora or https:// for published content."
    },
    "citation_label": {
      "type": "string",
      "minLength": 5,
      "description": "Preformatted citation label suitable for UI rendering without additional joins."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "escalation_required": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "escalation_target": {
            "type": "string",
            "minLength": 1
          },
          "escalation_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "else": {
        "properties": {
          "escalation_target": {
            "type": "null"
          },
          "escalation_reason": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "priority": {
            "const": "critical"
          }
        }
      },
      "then": {
        "properties": {
          "escalation_required": {
            "const": true
          }
        }
      }
    }
  ]
}
