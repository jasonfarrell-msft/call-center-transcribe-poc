@page
@model IndexModel
@{
    ViewData["Title"] = "Representative Console";
    ViewData["MainContainerClass"] = "console-page-shell";
    ViewData["BodyClass"] = "console-body";
    ViewData["MainClass"] = "console-main";
    ViewData["HideSiteChrome"] = true;
}

<div class="rep-console"
     data-console-refresh-root="true"
     data-console-refresh-interval-ms="4000"
     data-live-mode="@(Model.LiveMode ? "true" : "false")"
     data-api-base-url="@Model.ApiBaseUrl">
    <h1 class="visually-hidden">Call-Center Representative Console</h1>

    <nav class="screen-nav" aria-label="Console navigation">
        <span class="screen-nav-btn" aria-current="page">Agent Console</span>
        <span class="screen-nav-sep" aria-hidden="true">|</span>
        <a asp-page="/MissionControl" class="screen-nav-btn">Mission Control →</a>
    </nav>

    <section class="console-view console-view--representative"
             aria-labelledby="console-heading">
        <header class="card-shell console-header" data-console-refresh-region="@(Model.LiveMode ? null : "header")">
            <div class="console-header-top">
                <div>
                    <p class="console-eyebrow">Representative console</p>
                    <h2 id="console-heading" tabindex="-1">@Model.RepresentativeDisplayName</h2>
                    <p class="console-status" role="status" aria-live="polite" data-conn-summary>@Model.ConnectionSummary</p>
                </div>
            </div>

            @if (Model.HasConnectionIssues)
            {
                <div class="console-alert" role="alert">
                    <strong>Backend API connection issues detected.</strong>
                    <ul>
                        @foreach (var issue in Model.ConnectionIssues)
                        {
                            <li>@issue</li>
                        }
                    </ul>
                </div>
            }

            <dl class="console-call-meta" aria-label="Current call details">
                <div>
                    <dt>Call ID</dt>
                    <dd data-meta-callid>@Model.CallIdDisplay</dd>
                </div>
                <div>
                    <dt>Customer</dt>
                    <dd data-meta-customer>@Model.CustomerDisplayName</dd>
                </div>
                <div>
                    <dt>Connected</dt>
                    <dd data-meta-connected>@Model.ConnectionTimeDisplay</dd>
                </div>
            </dl>

            @if (Model.LiveMode)
            {
                <div class="rep-callbar" data-rep-callbar hidden
                     aria-label="Rep phone controls" role="region">
                    <span class="rep-callbar-status" data-rep-status aria-live="polite">Softphone starting…</span>
                    <div class="rep-callbar-actions">
                        <button type="button" class="rep-btn rep-btn--accept" data-rep-accept hidden>
                            <span aria-hidden="true">📞</span> Accept
                        </button>
                        <button type="button" class="rep-btn rep-btn--decline" data-rep-decline hidden>
                            <span aria-hidden="true">✕</span> Decline
                        </button>
                        <button type="button" class="rep-btn rep-btn--mute" data-rep-mute hidden aria-pressed="false">
                            <span aria-hidden="true">🎙️</span> <span data-rep-mute-label>Mute</span>
                        </button>
                        <button type="button" class="rep-btn rep-btn--hangup" data-rep-hangup hidden>
                            <span aria-hidden="true">⛔</span> Hang up
                        </button>
                    </div>
                </div>
            }
        </header>

        <div class="console-columns" data-console-refresh-region="@(Model.LiveMode ? null : "columns")">
            @if (Model.LiveMode)
            {
                <section class="card-shell console-main-column" aria-labelledby="transcript-heading">
                    <div class="panel-header">
                        <div>
                            <h2 id="transcript-heading">Transcript</h2>
                            <span class="visually-hidden">Live transcript from the active call</span>
                            <p class="panel-copy">Live transcription from the active call appears here in real time.</p>
                        </div>
                        <p class="panel-kicker conn-status conn-status--disconnected" data-conn-status role="status" aria-live="polite">
                            <span class="conn-dot" aria-hidden="true"></span>
                            <span data-conn-label>Disconnected — waiting for call</span>
                        </p>
                    </div>
                    <div class="transcript-scroller"
                         id="live-transcript"
                         data-live-transcript="true"
                         data-transcript-scroll="true"
                         tabindex="0"
                         role="log"
                         aria-live="polite"
                         aria-relevant="additions text"
                         aria-label="Live transcript feed">
                        <p class="console-empty-state" data-live-empty>Waiting for a call. Transcription will appear here in real time once a call connects.</p>
                        <p class="console-empty-state" data-live-pending hidden>Incoming call — accept to begin transcription.</p>
                    </div>
                </section>
            }
            else
            {
            <section class="card-shell console-main-column" aria-labelledby="transcript-heading">
                <div class="panel-header">
                    <div>
                        <h2 id="transcript-heading">Transcript</h2>
                        <span class="visually-hidden">Live transcript, diarization, and translation</span>
                        <p class="panel-copy">Diarization stays inline, and translation appears inside the live transcript.</p>
                    </div>
                    <p class="panel-kicker">@Model.FeedModeLabel</p>
                </div>

                <div class="transcript-scroller"
                     data-transcript-scroll="true"
                     tabindex="0"
                     role="log"
                     aria-live="polite"
                     aria-relevant="additions text"
                     aria-label="Live transcript feed">
                    @if (!string.IsNullOrWhiteSpace(Model.TranscriptWarning))
                    {
                        <p class="console-empty-state">@Model.TranscriptWarning</p>
                    }
                    else if (Model.TranscriptTimeline.Count == 0)
                    {
                        <p class="console-empty-state">Waiting for transcript activity.</p>
                    }
                    else
                    {
                        <ol class="transcript-list">
                            @foreach (var item in Model.TranscriptTimeline)
                            {
                                var translationPanelId = $"translation-{item.EventId}";
                                var translationContext = !string.IsNullOrWhiteSpace(item.SpeakerDisplayLabel)
                                    ? $"{item.SpeakerDisplayLabel} turn {item.Sequence}"
                                    : $"turn {item.Sequence}";
                                var showTranslationLabel = $"Show English translation for {translationContext}";
                                var hideTranslationLabel = $"Hide English translation for {translationContext}";
                                <li class="transcript-item" data-speaker-role="@item.SpeakerRoleLabel.ToLowerInvariant()">
                                    <article aria-labelledby="turn-@item.Sequence">
                                        <div class="transcript-topline">
                                            <div class="transcript-speaker-block">
                                                <h3 id="turn-@item.Sequence">@item.SpeakerDisplayLabel</h3>
                                                <p>@item.SpeakerRoleLabel</p>
                                            </div>
                                            <time datetime="@item.TimestampUtc.ToString("O")">@item.TimestampDisplay</time>
                                        </div>

                                        <p class="transcript-tags">
                                            <span>@item.SpeakerSourceLabel</span>
                                            <span>@item.SourceIndicator</span>
                                            <span>@item.DetectedLanguageCode.ToUpperInvariant() · @item.DetectedLanguageLabel</span>
                                            @if (item.IsNonEnglish && item.HasTranslation)
                                            {
                                                <button type="button"
                                                        class="btn btn-link transcript-action-link"
                                                        data-translation-toggle="true"
                                                        data-translation-target="@translationPanelId"
                                                        data-show-label="@showTranslationLabel"
                                                        data-hide-label="@hideTranslationLabel"
                                                        aria-controls="@translationPanelId"
                                                        aria-expanded="false"
                                                        aria-label="@showTranslationLabel">
                                                    @showTranslationLabel
                                                </button>
                                            }
                                            else if (item.IsNonEnglish)
                                            {
                                                <span class="transcript-action-disabled">Translation unavailable</span>
                                            }
                                        </p>

                                        @if (item.IsNonEnglish)
                                        {
                                            <p class="transcript-body" lang="@item.LanguageAttribute">@item.Text</p>
                                        }
                                        else
                                        {
                                            <p class="transcript-body">@item.Text</p>
                                        }

                                        @if (item.IsNonEnglish && item.HasTranslation)
                                        {
                                            <section id="@translationPanelId"
                                                     class="translation-panel"
                                                     aria-label="Translation"
                                                     hidden>
                                                <p class="translation-label">Translation (@item.TranslationTargetLanguageLabel)</p>
                                                <p lang="en" class="mb-0">@item.TranslationText</p>
                                            </section>
                                        }
                                    </article>
                                </li>
                            }
                        </ol>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.TranslationWarning))
                {
                    <p class="panel-footnote">@Model.TranslationWarning</p>
                }
            </section>
            }

            <aside class="console-side-column" aria-labelledby="sentiment-heading" data-console-refresh-region="@(Model.LiveMode ? null : "sentiment")">
                @if (Model.LiveMode)
                {
                    <section class="card-shell sentiment-panel" data-live-sentiment-panel>
                        <div class="panel-header panel-header--stacked">
                            <div>
                                <h2 id="sentiment-heading">Customer sentiment</h2>
                                <span class="visually-hidden">Sentiment indicator</span>
                                <span class="visually-hidden">Representative awareness</span>
                                <p class="panel-copy">A compact view of current customer tone.</p>
                            </div>
                        </div>
                        <p class="console-empty-state" data-live-sentiment-empty>Waiting for sentiment.</p>
                        <div data-live-sentiment-body hidden>
                            <div class="sentiment-score-block">
                                <p class="sentiment-score-label">Score</p>
                                <p class="sentiment-score-value">
                                    <span data-live-sentiment-score>--</span><span>/100</span>
                                </p>
                                <p class="sentiment-score-state" data-live-sentiment-state>Awaiting sentiment</p>
                            </div>
                            <div class="sentiment-meter" aria-hidden="true">
                                <span class="sentiment-meter-bar sentiment-meter-bar--steady" data-live-sentiment-meter style="width:0%"></span>
                            </div>
                            <p class="sentiment-meter-caption">0 = negative • 100 = positive</p>
                            <dl class="sentiment-details">
                                <div>
                                    <dt>Tone</dt>
                                    <dd data-live-sentiment-tone>Waiting for call</dd>
                                </div>
                                <div>
                                    <dt>Trend</dt>
                                    <dd data-live-sentiment-trend>Awaiting sentiment</dd>
                                </div>
                                <div>
                                    <dt>Updated</dt>
                                    <dd data-live-sentiment-updated>Waiting for call</dd>
                                </div>
                            </dl>
                            <p class="sentiment-summary" data-live-sentiment-summary hidden></p>
                        </div>
                    </section>

                    <section class="card-shell assist-panel" aria-labelledby="churn-heading" data-live-churn-panel>
                        <div class="panel-header panel-header--stacked">
                            <h2 id="churn-heading">Churn risk</h2>
                            <p class="panel-copy">Live churn guidance for the active call.</p>
                        </div>
                        <p class="console-empty-state" data-live-churn-empty>Waiting for churn signals.</p>
                        <div data-live-churn-body hidden>
                            <p class="assist-kicker" data-live-churn-level>Unknown</p>
                            <p class="assist-copy" data-live-churn-rationale></p>
                            <p class="assist-meta">Updated <span data-live-churn-updated>Waiting for call</span></p>
                        </div>
                    </section>

                    <section class="card-shell assist-panel" aria-labelledby="knowledge-heading" data-live-knowledge-panel>
                        <div class="panel-header panel-header--stacked">
                            <h2 id="knowledge-heading">Knowledge cards</h2>
                            <p class="panel-copy">Relevant snippets update as the call evolves.</p>
                        </div>
                        <p class="console-empty-state" data-live-knowledge-empty>Waiting for knowledge cards.</p>
                        <ul class="assist-list" data-live-knowledge-list hidden></ul>
                    </section>

                    <section class="card-shell assist-panel" aria-labelledby="next-best-heading" data-live-nba-panel>
                        <div class="panel-header panel-header--stacked">
                            <h2 id="next-best-heading">Next best action</h2>
                            <p class="panel-copy">Recommended move for the current moment.</p>
                        </div>
                        <p class="console-empty-state" data-live-nba-empty>Waiting for next-step guidance.</p>
                        <div data-live-nba-body hidden>
                            <p class="assist-kicker" data-live-nba-action></p>
                            <p class="assist-copy" data-live-nba-reasoning></p>
                            <p class="assist-meta">Confidence <span data-live-nba-confidence>--</span> • Updated <span data-live-nba-updated>Waiting for call</span></p>
                        </div>
                    </section>
                }
                else
                {
                    <section class="card-shell sentiment-panel">
                        <div class="panel-header panel-header--stacked">
                            <div>
                                <h2 id="sentiment-heading">Customer sentiment</h2>
                                <span class="visually-hidden">Sentiment indicator</span>
                                <span class="visually-hidden">Representative awareness</span>
                                <p class="panel-copy">A compact view of current customer tone.</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.SentimentWarning))
                        {
                            <p class="console-empty-state">@Model.SentimentWarning</p>
                        }
                        else if (!Model.Sentiment.HasData)
                        {
                            <p class="console-empty-state">Waiting for sentiment.</p>
                        }
                        else
                        {
                            @if (Model.Sentiment.ScorePercent is int sentimentScore)
                            {
                                <div class="sentiment-score-block">
                                    <p class="sentiment-score-label">Score</p>
                                    <p class="sentiment-score-value">
                                        @sentimentScore<span>/100</span>
                                    </p>
                                    <p class="sentiment-score-state">@Model.Sentiment.ScoreStateLabel</p>
                                </div>

                                <div class="sentiment-meter" aria-hidden="true">
                                    <span class="@Model.Sentiment.ScoreVisualClass" style="width:@sentimentScore%"></span>
                                </div>
                                <p class="sentiment-meter-caption">0 = negative • 100 = positive</p>
                            }

                            <dl class="sentiment-details">
                                <div>
                                    <dt>Tone</dt>
                                    <dd>@Model.Sentiment.ToneLabel</dd>
                                </div>
                                <div>
                                    <dt>Trend</dt>
                                    <dd>@Model.Sentiment.TrendLabel</dd>
                                </div>
                                <div>
                                    <dt>Updated</dt>
                                    <dd>@Model.Sentiment.UpdatedDisplay</dd>
                                </div>
                            </dl>

                            @if (!string.IsNullOrWhiteSpace(Model.Sentiment.SummaryText))
                            {
                                <p class="sentiment-summary">@Model.Sentiment.SummaryText</p>
                            }
                        }
                    </section>
                }
            </aside>
        </div>
    </section>
</div>

@section Scripts {
    @if (Model.LiveMode)
    {
        <script src="~/lib/signalr/dist/browser/signalr.min.js" asp-append-version="true"></script>
        <script src="~/js/live-transcript.js" asp-append-version="true"></script>
        <script src="~/lib/acs-calling/acs-calling.bundle.js" asp-append-version="true"></script>
        <script src="~/js/rep-phone.js" asp-append-version="true"></script>
    }
}
